
# ============================================================
# 古代临冲吕公车结构仿真与稳定性分析系统
# Docker Compose 环境变量配置文件
# ============================================================
# 复制此文件为 .env 并根据需要修改

# ---------- 全局 ----------
TZ=Asia/Shanghai

# ---------- 端口映射 ----------
FRONTEND_PORT=80
BACKEND_PORT=8080
CLICKHOUSE_PORT=8123
MQTT_PORT=1883
PROM_PORT=9090
GRAFANA_PORT=3000

# ---------- ClickHouse ----------
CLICKHOUSE_DB=siege_tower
CLICKHOUSE_USER=tower_user
CLICKHOUSE_PASSWORD=tower_secure_2024

# ---------- MQTT ----------
MQTT_ALERT_TOPIC=siege_tower/alert
MQTT_SENSOR_TOPIC=siege_tower/sensor
MQTT_ANALYSIS_TOPIC=siege_tower/analysis

# ---------- Rust后端 ----------
RUST_LOG=info,siege_tower_backend=debug,tower_http=info

# ---------- 传感器模拟器 ----------
SIM_MODE=hybrid
SIM_INTERVAL_SEC=5
SIM_TOWER_ID=1
SIM_TOWER_NAME=临冲吕公车-一号

# 风荷载配置
WIND_PROFILE=gusty          # calm / steady / gusty / ramp / typhoon
WIND_BASE_MPS=10.0          # 基础风速 m/s
WIND_MAX_MPS=40.0           # 最大风速 m/s
WIND_GUST_FACTOR=2.5        # 阵风放大系数
WIND_CHANGE_INTERVAL=120    # 风变化周期(秒)
WIND_DIRECTION=random       # random / fixed / rotate

# 土壤条件配置
SOIL_TYPE=sand              # sand / silt / clay / silt_soft / rock
SOIL_MOISTURE_PCT=15.0      # 基础含水率 %
SOIL_SETTLEMENT_MM=0.0      # 初始沉降 mm
SOIL_DYNAMIC=true           # 含水率动态变化(模拟降雨)

# 基础应力/倾斜
STRESS_BASE_MPA=25.0
TILT_BASE_DEG=0.5
TEMP_BASE_C=20.0
HUMIDITY_BASE_PCT=50.0

# 故障注入
INJECT_FAULTS=true
FAULT_PROBABILITY=0.02

# 输出模式
OUTPUT_MODE=both            # http / mqtt / both

API_BASE_URL=http://backend:8080
MQTT_BROKER=mqtt
MQTT_PORT=1883

# ---------- Grafana ----------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
